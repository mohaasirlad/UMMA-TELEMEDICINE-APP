<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/soft_gray">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_queue"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/queue_subtitle"
        android:textColor="@color/text_gray"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_current_position"
                android:textColor="@color/text_gray"
                android:letterSpacing="0.1"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQueueNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="80sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue" />

            <TextView
                android:id="@+id/tvEstimatedWait"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/queue_book_now"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:layout_marginTop="8dp" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/queueProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:progress="75"
                app:trackColor="@color/light_cyan"
                app:indicatorColor="@color/primary_blue" />

            <TextView
                android:id="@+id/tvPatientsAhead"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/queue_no_appointment"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Clinic Information"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UMMA Main Clinic - Branch A"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvQueueDoctorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room -- - Dr. --"
                android:textColor="@color/text_gray"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_cyan"
                android:layout_marginVertical="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewClinicMap"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Clinic Map"
                app:icon="@android:drawable/ic_menu_directions" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>